# App Config
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://simakel_user:simakel_password@localhost:5432/simakel_db
DATABASE_POOL_SIZE=10
DATABASE_POOL_IDLE_TIMEOUT=30000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_in_production_minimum_32_chars
JWT_EXPIRATION=5m
JWT_REFRESH_EXPIRATION=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DIR=./uploads

# Sync Config
AUTO_SYNC_INTERVAL=300000
MAX_SYNC_RETRIES=3
SYNC_TIMEOUT=30000
BATCH_SIZE=100
DEBOUNCE_DELAY=1000

# Security
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=your_encryption_key_32_chars_long_minimum
AUTO_LOGOUT_TIME=1800000

# Email (Optional)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@simakel.local

# Logging
LOG_FORMAT=json
